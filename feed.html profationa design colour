<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>OurMarket - Professional Marketplace Dashboard</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>

<style>

/* =========================================================
   PROFESSIONAL MARKETPLACE DASHBOARD - COMPLETE CSS
   Designed for high ad approval rates & responsive perfection
   Version: 1.0 | Clean | Trustworthy | Modern
========================================================= */

:root {
  /* Primary Brand Colors - Safe, Trustworthy Blues */
  --primary: #2563eb;
  --primary-dark: #1d4ed8;
  --primary-light: #eff6ff;
  --primary-soft: #3b82f6;
  
  /* Semantic Colors */
  --success: #10b981;
  --success-light: #d1fae5;
  --danger: #ef4444;
  --danger-light: #fee2e2;
  --warning: #f59e0b;
  --warning-light: #fef3c7;
  --info: #6366f1;
  
  /* Neutral Palette */
  --dark: #0f172a;
  --dark-soft: #1e293b;
  --gray-900: #111827;
  --gray-800: #1f2937;
  --gray-700: #374151;
  --gray-600: #4b5563;
  --gray-500: #6b7280;
  --gray-400: #9ca3af;
  --gray-300: #d1d5db;
  --gray-200: #e5e7eb;
  --gray-100: #f3f4f6;
  --gray-50: #f9fafb;
  
  /* Backgrounds */
  --bg-page: #f8fafc;
  --bg-card: #ffffff;
  --bg-sidebar: linear-gradient(180deg, #0f172a 0%, #111827 100%);
  
  /* Shadows - Soft & Realistic */
  --shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.03);
  --shadow-sm: 0 1px 3px 0 rgba(0, 0, 0, 0.05), 0 1px 2px -1px rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -4px rgba(0, 0, 0, 0.05);
  --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
  --shadow-glow: 0 0 0 1px rgba(37, 99, 235, 0.1), 0 4px 12px rgba(0, 0, 0, 0.05);
  
  /* Border Radius */
  --radius-xs: 6px;
  --radius-sm: 10px;
  --radius-md: 14px;
  --radius-lg: 20px;
  --radius-xl: 28px;
  --radius-2xl: 36px;
  --radius-full: 9999px;
  
  /* Sidebar Width */
  --sidebar-width: 280px;
  --sidebar-width-collapsed: 88px;
  
  /* Transitions */
  --transition-fast: 150ms cubic-bezier(0.4, 0, 0.2, 1);
  --transition-base: 200ms cubic-bezier(0.4, 0, 0.2, 1);
  --transition-slow: 300ms cubic-bezier(0.4, 0, 0.2, 1);
  
  /* Typography Scale */
  --text-xs: 0.75rem;
  --text-sm: 0.875rem;
  --text-base: 1rem;
  --text-lg: 1.125rem;
  --text-xl: 1.25rem;
  --text-2xl: 1.5rem;
  --text-3xl: 1.875rem;
  --text-4xl: 2.25rem;
  --text-5xl: 3rem;
  
  /* Font Weights */
  --font-normal: 400;
  --font-medium: 500;
  --font-semibold: 600;
  --font-bold: 700;
  --font-extrabold: 800;
}

/* Reset & Base Styles - Pixel Perfect */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  background: var(--bg-page);
  color: var(--gray-900);
  line-height: 1.5;
  min-height: 100vh;
  position: relative;
  overflow-x: hidden;
}

/* Typography Refinements */
h1, h2, h3, h4, h5, h6 {
  font-weight: var(--font-semibold);
  letter-spacing: -0.02em;
  line-height: 1.3;
}

/* Custom Scrollbar - Professional */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: var(--gray-100);
  border-radius: var(--radius-full);
}

::-webkit-scrollbar-thumb {
  background: var(--gray-400);
  border-radius: var(--radius-full);
}

::-webkit-scrollbar-thumb:hover {
  background: var(--gray-500);
}

/* Selection Color */
::selection {
  background: var(--primary-light);
  color: var(--primary);
}

/* =========================================================
   LAYOUT & STRUCTURE
========================================================= */

/* Mobile Menu Button - Accessible & Premium */
.mobile-menu-btn {
  display: none;
  position: fixed;
  top: 20px;
  left: 20px;
  width: 48px;
  height: 48px;
  border: none;
  border-radius: var(--radius-md);
  background: var(--bg-card);
  color: var(--gray-700);
  font-size: 20px;
  z-index: 3000;
  box-shadow: var(--shadow-lg);
  cursor: pointer;
  transition: all var(--transition-fast);
  backdrop-filter: blur(8px);
  background: rgba(255, 255, 255, 0.95);
  border: 1px solid var(--gray-200);
}

.mobile-menu-btn:hover {
  background: var(--primary);
  color: white;
  transform: scale(0.98);
}

/* Sidebar - Professional Navigation */
.sidebar {
  width: var(--sidebar-width);
  background: var(--bg-sidebar);
  backdrop-filter: blur(10px);
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  padding: 28px 20px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  z-index: 2000;
  transition: transform var(--transition-slow);
  border-right: 1px solid rgba(255, 255, 255, 0.05);
  overflow-y: auto;
}

/* Brand Section */
.brand {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 40px;
  padding: 0 8px;
}

.brand-logo {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-soft) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  color: white;
  box-shadow: var(--shadow-glow);
}

.brand h2 {
  font-size: 22px;
  font-weight: var(--font-extrabold);
  background: linear-gradient(135deg, #ffffff 0%, #94a3b8 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  letter-spacing: -0.5px;
}

/* Navigation Items */
.nav {
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}

.nav-link {
  text-decoration: none;
  color: var(--gray-400);
  padding: 14px 18px;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  gap: 14px;
  transition: all var(--transition-fast);
  font-weight: var(--font-medium);
  font-size: var(--text-sm);
  position: relative;
}

.nav-link i {
  width: 22px;
  font-size: 18px;
  transition: transform var(--transition-fast);
}

.nav-link:hover {
  background: rgba(255, 255, 255, 0.06);
  color: white;
  transform: translateX(4px);
}

.nav-link:hover i {
  transform: scale(1.05);
}

.nav-link.active {
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.15) 0%, rgba(59, 130, 246, 0.08) 100%);
  color: white;
  border-left: 3px solid var(--primary);
}

/* Logout Button */
.logout-btn {
  border: none;
  padding: 14px 18px;
  border-radius: var(--radius-md);
  background: rgba(239, 68, 68, 0.1);
  color: var(--danger);
  font-weight: var(--font-semibold);
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  transition: all var(--transition-fast);
  width: 100%;
  margin-top: 20px;
  font-size: var(--text-sm);
}

.logout-btn:hover {
  background: var(--danger);
  color: white;
  transform: translateY(-2px);
}

/* Main Content Area */
.main {
  margin-left: var(--sidebar-width);
  width: calc(100% - var(--sidebar-width));
  padding: 32px 36px;
  min-height: 100vh;
  transition: margin var(--transition-slow);
}

/* =========================================================
   TOPBAR SECTION
========================================================= */

.topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 24px;
  margin-bottom: 36px;
}

.welcome h1 {
  font-size: var(--text-3xl);
  font-weight: var(--font-extrabold);
  background: linear-gradient(135deg, var(--gray-900) 0%, var(--gray-700) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  letter-spacing: -0.02em;
}

.welcome p {
  color: var(--gray-500);
  font-size: var(--text-sm);
  margin-top: 6px;
  font-weight: var(--font-medium);
}

/* Search Box - Professional */
.search-box {
  position: relative;
  min-width: 280px;
}

.search-box i {
  position: absolute;
  left: 16px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--gray-400);
  font-size: 16px;
  pointer-events: none;
}

.search-box input {
  width: 100%;
  padding: 14px 16px 14px 46px;
  border: 1px solid var(--gray-200);
  outline: none;
  border-radius: var(--radius-md);
  background: var(--bg-card);
  font-size: var(--text-sm);
  transition: all var(--transition-fast);
  box-shadow: var(--shadow-xs);
}

.search-box input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

/* Profile Mini Card */
.profile-mini {
  background: var(--bg-card);
  padding: 10px 18px;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  gap: 14px;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--gray-100);
  transition: all var(--transition-fast);
}

.profile-mini:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-1px);
}

.profile-mini img {
  width: 44px;
  height: 44px;
  border-radius: var(--radius-full);
  object-fit: cover;
  border: 2px solid var(--gray-100);
}

.profile-mini strong {
  font-size: var(--text-sm);
  color: var(--gray-900);
}

.profile-mini small {
  font-size: var(--text-xs);
  color: var(--gray-500);
}

/* =========================================================
   STATS CARDS - METRICS THAT TRUST
========================================================= */

.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 24px;
  margin-bottom: 32px;
}

.stat-card {
  background: var(--bg-card);
  padding: 24px;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--gray-100);
  transition: all var(--transition-base);
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--primary), var(--primary-soft));
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  opacity: 0;
  transition: opacity var(--transition-fast);
}

.stat-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}

.stat-card:hover::before {
  opacity: 1;
}

.stat-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.stat-card p {
  color: var(--gray-500);
  font-size: var(--text-sm);
  font-weight: var(--font-medium);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.stat-card h3 {
  font-size: var(--text-3xl);
  font-weight: var(--font-extrabold);
  margin-top: 12px;
  color: var(--gray-900);
}

.stat-icon {
  width: 52px;
  height: 52px;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 22px;
  transition: transform var(--transition-fast);
}

.stat-card:hover .stat-icon {
  transform: scale(1.05);
}

.stat-icon.blue { background: linear-gradient(135deg, var(--primary) 0%, var(--primary-soft) 100%); }
.stat-icon.green { background: linear-gradient(135deg, var(--success) 0%, #34d399 100%); }
.stat-icon.orange { background: linear-gradient(135deg, var(--warning) 0%, #fbbf24 100%); }
.stat-icon.dark { background: linear-gradient(135deg, var(--gray-800) 0%, var(--gray-600) 100%); }

/* =========================================================
   CARDS - CLEAN & AIRY
========================================================= */

.card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 32px;
  margin-bottom: 32px;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--gray-100);
  transition: all var(--transition-base);
}

.card:hover {
  box-shadow: var(--shadow-md);
}

.card-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28px;
  flex-wrap: wrap;
  gap: 16px;
  padding-bottom: 16px;
  border-bottom: 2px solid var(--gray-100);
}

.card-title h2 {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--gray-900);
  letter-spacing: -0.3px;
}

/* =========================================================
   FORM ELEMENTS - PROFESSIONAL INPUTS
========================================================= */

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
}

.full {
  grid-column: 1 / -1;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

label {
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  color: var(--gray-700);
  letter-spacing: -0.2px;
}

input, textarea, select {
  width: 100%;
  border: 1px solid var(--gray-200);
  padding: 14px 16px;
  border-radius: var(--radius-md);
  outline: none;
  font-size: var(--text-sm);
  transition: all var(--transition-fast);
  background: var(--bg-card);
  color: var(--gray-900);
}

input:focus, textarea:focus, select:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

textarea {
  min-height: 120px;
  resize: vertical;
  font-family: inherit;
}

/* File Input Styling */
input[type="file"] {
  padding: 12px;
  background: var(--gray-50);
  cursor: pointer;
}

input[type="file"]::file-selector-button {
  padding: 8px 16px;
  border-radius: var(--radius-sm);
  border: none;
  background: var(--primary-light);
  color: var(--primary);
  font-weight: var(--font-semibold);
  cursor: pointer;
  margin-right: 12px;
}

/* =========================================================
   BUTTONS - ACTIONABLE & CLEAR
========================================================= */

.btn {
  border: none;
  padding: 14px 24px;
  border-radius: var(--radius-md);
  font-weight: var(--font-semibold);
  font-size: var(--text-sm);
  transition: all var(--transition-fast);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-soft) 100%);
  color: white;
  box-shadow: 0 2px 6px rgba(37, 99, 235, 0.2);
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 14px rgba(37, 99, 235, 0.25);
}

.btn-secondary {
  background: var(--primary-light);
  color: var(--primary);
  border: 1px solid transparent;
}

.btn-secondary:hover {
  background: #e0e7ff;
  transform: translateY(-1px);
}

.btn-danger {
  background: var(--danger-light);
  color: var(--danger);
}

.btn-danger:hover {
  background: #fecaca;
  transform: translateY(-1px);
}

/* =========================================================
   PRODUCT GRID & CARDS
========================================================= */

.products-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 28px;
}

.product-card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-base);
  border: 1px solid var(--gray-100);
}

.product-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-xl);
}

.product-card img {
  width: 100%;
  height: 260px;
  object-fit: cover;
  cursor: pointer;
  transition: transform var(--transition-slow);
}

.product-card:hover img {
  transform: scale(1.02);
}

.product-body {
  padding: 24px;
}

.category {
  display: inline-block;
  background: var(--primary-light);
  color: var(--primary);
  padding: 6px 14px;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: var(--font-semibold);
  margin-bottom: 16px;
}

.product-body h3 {
  font-size: var(--text-xl);
  margin-bottom: 12px;
  font-weight: var(--font-bold);
}

.price {
  font-size: var(--text-2xl);
  font-weight: var(--font-extrabold);
  color: var(--primary);
  margin-bottom: 16px;
}

.meta {
  display: flex;
  flex-direction: column;
  gap: 10px;
  color: var(--gray-500);
  font-size: var(--text-sm);
  margin-bottom: 20px;
}

.meta i {
  width: 20px;
  margin-right: 8px;
  color: var(--gray-400);
}

.product-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.product-actions .btn {
  flex: 1;
}

/* =========================================================
   PROFILE SECTION
========================================================= */

.profile-upload {
  display: flex;
  align-items: center;
  gap: 28px;
  flex-wrap: wrap;
  margin-bottom: 32px;
  padding: 20px;
  background: var(--gray-50);
  border-radius: var(--radius-lg);
}

.profile-upload img {
  width: 100px;
  height: 100px;
  border-radius: var(--radius-full);
  object-fit: cover;
  border: 3px solid white;
  box-shadow: var(--shadow-md);
}

/* Product Image Preview */
.product-image-preview {
  width: 100%;
  height: 320px;
  object-fit: cover;
  border-radius: var(--radius-lg);
  margin-bottom: 28px;
  background: var(--gray-100);
  cursor: pointer;
  transition: opacity var(--transition-fast);
}

.product-image-preview:hover {
  opacity: 0.9;
}

/* Empty State */
.empty {
  background: var(--bg-card);
  padding: 64px 48px;
  border-radius: var(--radius-xl);
  text-align: center;
  color: var(--gray-500);
  box-shadow: var(--shadow-sm);
  border: 1px dashed var(--gray-300);
}

.empty i {
  font-size: 64px;
  margin-bottom: 20px;
  color: var(--gray-400);
}

.empty h2 {
  font-size: var(--text-xl);
  margin-bottom: 8px;
  color: var(--gray-600);
}

/* =========================================================
   LOADER & MODALS
========================================================= */

.loader {
  position: fixed;
  inset: 0;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(4px);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 99999;
}

.spinner {
  width: 56px;
  height: 56px;
  border: 3px solid var(--gray-200);
  border-top: 3px solid var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Image Modal - Full Screen Viewer */
.image-modal {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.92);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 999999;
  padding: 24px;
}

.image-modal.active {
  display: flex;
}

.image-modal img {
  max-width: 90%;
  max-height: 85vh;
  border-radius: var(--radius-lg);
  object-fit: contain;
  box-shadow: var(--shadow-xl);
  animation: zoomIn 0.2s ease-out;
}

@keyframes zoomIn {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.close-modal {
  position: absolute;
  top: 24px;
  right: 28px;
  width: 48px;
  height: 48px;
  border: none;
  border-radius: var(--radius-full);
  background: white;
  color: var(--gray-900);
  font-size: 20px;
  cursor: pointer;
  transition: all var(--transition-fast);
  box-shadow: var(--shadow-lg);
}

.close-modal:hover {
  background: var(--danger);
  color: white;
  transform: scale(1.05);
}

/* =========================================================
   RESPONSIVE DESIGN - MOBILE & TABLET OPTIMIZED
========================================================= */

/* Tablet & Medium Screens */
@media (max-width: 1024px) {
  .main {
    padding: 28px 24px;
  }
  
  .stats-grid {
    gap: 20px;
  }
  
  .products-grid {
    gap: 24px;
  }
}

/* Mobile & Small Tablets */
@media (max-width: 950px) {
  .mobile-menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .sidebar {
    transform: translateX(-100%);
    width: 280px;
    box-shadow: var(--shadow-xl);
  }
  
  .sidebar.active {
    transform: translateX(0);
  }
  
  .main {
    margin-left: 0;
    width: 100%;
    padding: 24px 20px;
    padding-top: 88px;
  }
  
  .topbar {
    flex-direction: column;
