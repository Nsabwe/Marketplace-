<script>

/* =========================================================
   PROFESSIONAL MARKETPLACE DASHBOARD
   FULL UPGRADE VERSION
   KEEPING SAME UI / DESIGN
========================================================= */

/* =========================================================
   CONFIG
========================================================= */

const API_URL =
"https://v2-dashibord-server-11cln.onrender.com/api";

const DEFAULT_PRODUCT_IMAGE =
"https://images.unsplash.com/photo-1523275335684-37898b6baf30?q=80&w=1200&auto=format&fit=crop";

const token =
localStorage.getItem("token");

if (!token) {
  window.location.href = "/login.html";
}

/* =========================================================
   HELPERS
========================================================= */

const $ = id =>
document.getElementById(id);

const elements = {
  loader: $("loader"),
  sidebar: $("sidebar"),
  productsGrid: $("productsGrid"),
  imageModal: $("imageModal"),
  modalImage: $("modalImage")
};

const navLinks =
document.querySelectorAll(".nav-link");

const sections =
document.querySelectorAll(".section");

/* =========================================================
   GLOBAL STATE
========================================================= */

let products = [];
let profile = {};
let editingProductId = null;

/* =========================================================
   API CLIENT
========================================================= */

async function api(
  endpoint,
  options = {}
){

  try {

    const response = await fetch(
      `${API_URL}${endpoint}`,
      {
        ...options,

        headers: {
          Authorization:
          `Bearer ${token}`,

          ...(options.body &&
          !(options.body instanceof FormData)
            ? {
                "Content-Type":
                "application/json"
              }
            : {}),

          ...(options.headers || {})
        }
      }
    );

    const data =
    await response.json();

    if (!response.ok) {
      throw new Error(
        data.message ||
        "Request failed"
      );
    }

    return data;

  } catch (error) {

    console.error(error);

    throw error;
  }
}

/* =========================================================
   UI UTILITIES
========================================================= */

function showLoader() {
  elements.loader.style.display = "flex";
}

function hideLoader() {
  elements.loader.style.display = "none";
}

function showToast(message) {
  alert(message);
}

function openImage(src) {

  elements.modalImage.src = src;

  elements.imageModal
  .classList.add("active");
}

function closeImage() {

  elements.imageModal
  .classList.remove("active");
}

/* =========================================================
   MOBILE MENU
========================================================= */

$("mobileMenuBtn")
.addEventListener(
  "click",
  () => {

    elements.sidebar
    .classList.toggle("active");

  }
);

/* =========================================================
   NAVIGATION
========================================================= */

navLinks.forEach(link => {

  link.addEventListener(
    "click",
    e => {

      e.preventDefault();

      navLinks.forEach(item =>
        item.classList
        .remove("active")
      );

      sections.forEach(section =>
        section.classList
        .remove("active")
      );

      link.classList.add("active");

      $(
        `${link.dataset.section}-section`
      )
      .classList.add("active");

      if (
        window.innerWidth < 950
      ) {

        elements.sidebar
        .classList.remove("active");

      }

    }
  );

});

/* =========================================================
   IMAGE MODAL
========================================================= */

$("closeModal")
.addEventListener(
  "click",
  closeImage
);

elements.imageModal
.addEventListener(
  "click",
  e => {

    if (
      e.target ===
      elements.imageModal
    ) {
      closeImage();
    }

  }
);

/* =========================================================
   IMAGE PREVIEW
========================================================= */

$("productImage")
.addEventListener(
  "change",
  previewProductImage
);

$("profileImageInput")
.addEventListener(
  "change",
  previewProfileImage
);

function previewProductImage(e) {

  const file =
  e.target.files[0];

  if (!file) return;

  const reader =
  new FileReader();

  reader.onload = event => {

    $("productPreview").src =
    event.target.result;

  };

  reader.readAsDataURL(file);
}

function previewProfileImage(e) {

  const file =
  e.target.files[0];

  if (!file) return;

  const reader =
  new FileReader();

  reader.onload = event => {

    $("profilePreview").src =
    event.target.result;

    $("miniAvatar").src =
    event.target.result;

  };

  reader.readAsDataURL(file);
}

/* =========================================================
   LOAD PROFILE
========================================================= */

async function loadProfile() {

  try {

    const data =
    await api("/profile");

    profile = data.user || data;

    $("firstName").value =
    profile.firstName || "";

    $("lastName").value =
    profile.lastName || "";

    $("phone").value =
    profile.phone || "";

    $("country").value =
    profile.country || "";

    $("location").value =
    profile.location || "";

    $("bio").value =
    profile.bio || "";

    $("miniName").innerText =
    `${profile.firstName || ""}
    ${profile.lastName || ""}`;

    if (profile.avatar) {

      $("profilePreview").src =
      profile.avatar;

      $("miniAvatar").src =
      profile.avatar;
    }

  } catch (error) {

    showToast(
      error.message
    );

  }

}

/* =========================================================
   SAVE PROFILE
========================================================= */

$("saveProfileBtn")
.addEventListener(
  "click",
  saveProfile
);

// SAVE PROFILE - FIXED VERSION
async function saveProfile() {
  try {
    showLoader();
    
    // Get all form elements and check they exist
    const firstNameEl = $("#firstName");
    const lastNameEl = $("#lastName");
    const phoneEl = $("#phone");
    const countryEl = $("#country");
    const locationEl = $("#location");
    const bioEl = $("#bio");
    const avatarFile = $("#profileImageInput").files[0];
    
    // Validate all required elements exist
    if (!firstNameEl || !lastNameEl || !phoneEl || !countryEl || !locationEl || !bioEl) {
      showToast("Form elements not found");
      return;
    }
    
    const formData = new FormData();
    formData.append('firstName', firstNameEl.value);
    formData.append('lastName', lastNameEl.value);
    formData.append('phone', phoneEl.value);
    formData.append('country', countryEl.value);
    formData.append('location', locationEl.value);
    formData.append('bio', bioEl.value);
    
    // Get avatar file if changed
    if (avatarFile) {
      formData.append('avatar', avatarFile);
    }

    const response = await fetch(`${API_URL}/profile`, {
      method: "PUT",
      headers: {
        'Authorization': `Bearer ${token}`
      },
      body: formData
    });

    const data = await response.json();
    if (!response.ok) throw new Error(data.message || "Update failed");

    // Update UI with new data
    if (data.avatar) {
      $("#profilePreview").src = data.avatar;
      $("#miniAvatar").src = data.avatar;
    }
    
    // Update mini name display
    $("#miniName").innerText = `${data.firstName || firstNameEl.value || ""} ${data.lastName || lastNameEl.value || ""}`.trim();
    
    showToast("Profile updated successfully");
  } catch (error) {
    console.error("Save profile error:", error);
    showToast(error.message);
  } finally {
    hideLoader();
  }
}

/* =========================================================
   LOAD PRODUCTS
========================================================= */

async function loadProducts() {
  try {
    showLoader();
    const data = await api("/products/my"); // Changed from "/products"
    products = data.products || data || [];
    renderProducts();
    updateStats();
  } catch (error) {
    showToast(error.message);
  } finally {
    hideLoader();
  }
}

/* =========================================================
   ADD / UPDATE PRODUCT
========================================================= */

$("addProductBtn")
.addEventListener(
  "click",
  saveProduct
);

async function saveProduct() {
  try {
    const name = $("productName").value.trim();
    const price = $("price").value.trim();
    const location = $("productLocation").value.trim();

    if (!name || !price || !location) {
      return showToast("Please fill all required fields");
    }

    showLoader();

    // Create FormData instead of JSON
    const formData = new FormData();
    formData.append('name', name);
    formData.append('category', $("productCategory").value);
    formData.append('currency', $("currency").value);
    formData.append('price', price);
    formData.append('stock', $("stock").value);
    formData.append('description', $("description").value);
    formData.append('location', location);
    
    // Add image file if selected
    const imageFile = $("productImage").files[0];
    if (imageFile) {
      formData.append('image', imageFile);
    }

    let data;

    if (editingProductId) {
      data = await api(`/products/${editingProductId}`, {
        method: "PUT",
        body: formData
      });

      products = products.map(product =>
        product._id === editingProductId ? data : product
      );

      editingProductId = null;
      $("addProductBtn").innerHTML = `<i class="fa-solid fa-plus"></i> Add Product`;
      showToast("Product updated");
    } else {
      data = await api("/products", {
        method: "POST",
        body: formData
      });

      products.unshift(data);
      showToast("Product added");
    }

    renderProducts();
    updateStats();
    resetForm();

  } catch (error) {
    showToast(error.message);
  } finally {
    hideLoader();
  }
}

/* =========================================================
   RESET FORM
========================================================= */

function resetForm() {

  editingProductId = null;

  [
    "productName",
    "price",
    "stock",
    "description",
    "productLocation",
    "productImage"
  ]
  .forEach(id => {

    $(id).value = "";

  });

  $("productPreview").src =
  DEFAULT_PRODUCT_IMAGE;

}

/* =========================================================
   RENDER PRODUCTS
========================================================= */

function renderProducts(
  items = products
){

  if (!items.length) {

    elements.productsGrid.innerHTML = `
      <div class="empty">

        <i class="fa-solid fa-box-open"
        style="
        font-size:60px;
        margin-bottom:20px;
        "></i>

        <h2>No Products Found</h2>

        <p style="margin-top:10px;">
        Add your first product now
        </p>

      </div>
    `;

    return;
  }

  elements.productsGrid.innerHTML =
  items.map(product => `

    <div class="product-card">

      <img
      src="${
        product.image ||
        DEFAULT_PRODUCT_IMAGE
      }"

      onclick="
      openImage(
      '${
        product.image ||
        DEFAULT_PRODUCT_IMAGE
      }'
      )
      ">

      <div class="product-body">

        <span class="category">
        ${product.category}
        </span>

        <h3>${product.name}</h3>

        <div class="price">

        ${product.currency}

        ${Number(
          product.price || 0
        ).toLocaleString()}

        </div>

        <div class="meta">

          <span>

          <i class="
          fa-solid
          fa-location-dot
          "></i>

          ${product.location}

          </span>

          <span>

          <i class="
          fa-solid
          fa-cubes
          "></i>

          Stock:
          ${product.stock || 0}

          </span>

        </div>

        <div class="product-actions">

          <button
          class="btn btn-secondary"
          onclick="
          editProduct(
          '${product._id}'
          )
          ">

          Edit

          </button>

          <button
          class="btn btn-danger"
          onclick="
          deleteProduct(
          '${product._id}'
          )
          ">

          Delete

          </button>

        </div>

      </div>

    </div>

  `).join("");

}

/* =========================================================
   EDIT PRODUCT
========================================================= */

function editProduct(id) {

  const product =
  products.find(
    p => p._id === id
  );

  if (!product) return;

  editingProductId = id;

  $("productName").value =
  product.name;

  $("productCategory").value =
  product.category;

  $("currency").value =
  product.currency;

  $("price").value =
  product.price;

  $("stock").value =
  product.stock;

  $("description").value =
  product.description;

  $("productLocation").value =
  product.location;

  $("productPreview").src =
  product.image ||
  DEFAULT_PRODUCT_IMAGE;

  $("addProductBtn")
  .innerHTML = `
  <i class="fa-solid fa-pen"></i>
  Update Product
  `;

  document
  .querySelector(
    '[data-section="add-product"]'
  )
  .click();

}

/* =========================================================
   DELETE PRODUCT
========================================================= */

async function deleteProduct(id) {

  if (
    !confirm(
      "Delete this product?"
    )
  ) return;

  try {

    showLoader();

    await api(
      `/products/${id}`,
      {
        method: "DELETE"
      }
    );

    products =
    products.filter(
      product =>
      product._id !== id
    );

    renderProducts();

    updateStats();

    showToast(
      "Product deleted"
    );

  } catch (error) {

    showToast(error.message);

  } finally {

    hideLoader();

  }

}

/* =========================================================
   SEARCH
========================================================= */

$("searchInput")
.addEventListener(
  "input",
  e => {

    const value =
    e.target.value
    .toLowerCase();

    const filtered =
    products.filter(product =>

      product.name
      .toLowerCase()
      .includes(value)

      ||

      product.category
      .toLowerCase()
      .includes(value)

    );

    renderProducts(filtered);

  }
);

/* =========================================================
   DASHBOARD STATS
========================================================= */

function updateStats() {

  $("totalProducts").innerText =
  products.length;

  const total =
  products.reduce(
    (sum, product) =>

      sum +
      Number(
        product.price || 0
      ),

    0
  );

  $("totalSales").innerText =
  "$" +
  total.toLocaleString();

  $("totalOrders").innerText =
  Math.floor(
    products.length * 2.3
  );

  $("visitors").innerText =
  (
    products.length * 137
  ) + "+";

}

/* =========================================================
   LOGOUT
========================================================= */

$("logoutBtn")
.addEventListener(
  "click",
  logout
);

function logout() {

  if (
    !confirm("Logout now?")
  ) return;

  localStorage.removeItem(
    "token"
  );

  window.location.href =
  "/login.html";
}

/* =========================================================
   INITIALIZE APP
========================================================= */

async function init() {

  await Promise.all([
    loadProfile(),
    loadProducts()
  ]);

}

init();
</script>

</body>
</html>
