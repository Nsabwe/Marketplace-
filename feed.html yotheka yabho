<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>OurMarket - Professional Marketplace Dashboard</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>

<style>

:root{
  --primary:#2563eb;
  --primary-dark:#1d4ed8;
  --success:#16a34a;
  --danger:#dc2626;
  --warning:#ea580c;

  --dark:#0f172a;
  --dark-2:#111827;

  --bg:#f4f7fb;
  --card:#ffffff;
  --text:#0f172a;
  --muted:#64748b;
  --border:#e2e8f0;

  --radius:22px;
  --sidebar-width:280px;

  --shadow:
  0 10px 30px rgba(15,23,42,.08);
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

html{
  scroll-behavior:smooth;
}

body{
  font-family:"Inter",sans-serif;
  background:var(--bg);
  color:var(--text);
  display:flex;
  min-height:100vh;
  overflow-x:hidden;
}

/* ======================
   GLOBAL
====================== */

img{
  max-width:100%;
  display:block;
}

button,
input,
textarea,
select{
  font-family:inherit;
}

.section{
  display:none;
}

.section.active{
  display:block;
}

/* ======================
   MOBILE BUTTON
====================== */

.mobile-menu-btn{
  display:none;
  position:fixed;
  top:15px;
  left:15px;
  width:52px;
  height:52px;
  border:none;
  border-radius:16px;
  background:var(--primary);
  color:white;
  z-index:3000;
  cursor:pointer;
  font-size:20px;
  box-shadow:var(--shadow);
}

/* ======================
   SIDEBAR
====================== */

.sidebar{
  width:var(--sidebar-width);
  background:linear-gradient(180deg,var(--dark),var(--dark-2));
  color:white;

  position:fixed;
  top:0;
  left:0;
  bottom:0;

  padding:24px 18px;

  display:flex;
  flex-direction:column;
  justify-content:space-between;

  z-index:2000;
}

.brand{
  display:flex;
  align-items:center;
  gap:14px;
  margin-bottom:40px;
}

.brand-logo{
  width:60px;
  height:60px;
  border-radius:18px;
  background:linear-gradient(135deg,#2563eb,#60a5fa);

  display:flex;
  align-items:center;
  justify-content:center;

  font-size:25px;
}

.brand h2{
  font-size:24px;
  font-weight:800;
}

.nav{
  display:flex;
  flex-direction:column;
  gap:10px;
}

.nav-link{
  text-decoration:none;
  color:#cbd5e1;
  padding:16px 18px;
  border-radius:18px;

  display:flex;
  align-items:center;
  gap:14px;

  transition:.25s;
  font-weight:600;
}

.nav-link:hover,
.nav-link.active{
  background:rgba(255,255,255,.08);
  color:white;
}

.logout-btn{
  border:none;
  padding:16px;
  border-radius:18px;
  cursor:pointer;

  background:linear-gradient(135deg,#ef4444,#dc2626);
  color:white;

  font-weight:700;
}

/* ======================
   MAIN
====================== */

.main{
  margin-left:var(--sidebar-width);
  width:calc(100% - var(--sidebar-width));
  padding:30px;
}

/* ======================
   TOPBAR
====================== */

.topbar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:20px;
  flex-wrap:wrap;
  margin-bottom:30px;
}

.welcome h1{
  font-size:36px;
  font-weight:800;
}

.welcome p{
  color:var(--muted);
  margin-top:6px;
}

.top-actions{
  display:flex;
  align-items:center;
  gap:15px;
  flex-wrap:wrap;
}

.search-box{
  position:relative;
}

.search-box i{
  position:absolute;
  left:16px;
  top:50%;
  transform:translateY(-50%);
  color:var(--muted);
}

.search-box input{
  width:280px;
  border:none;
  outline:none;
  background:white;
  padding:15px 18px 15px 48px;
  border-radius:16px;
  box-shadow:var(--shadow);
}

.profile-mini{
  background:white;
  padding:10px 15px;
  border-radius:16px;
  box-shadow:var(--shadow);

  display:flex;
  align-items:center;
  gap:12px;
}

.profile-mini img{
  width:50px;
  height:50px;
  border-radius:50%;
  object-fit:cover;
}

/* ======================
   BUTTONS
====================== */

.btn{
  border:none;
  padding:15px 22px;
  border-radius:16px;
  cursor:pointer;

  font-weight:700;
  transition:.25s;
}

.btn:hover{
  transform:translateY(-2px);
}

.btn-primary{
  background:linear-gradient(135deg,#2563eb,#60a5fa);
  color:white;
}

.btn-danger{
  background:#fef2f2;
  color:var(--danger);
}

.btn-secondary{
  background:#eff6ff;
  color:var(--primary);
}

/* ======================
   STATS
====================== */

.stats-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
  gap:22px;
  margin-bottom:28px;
}

.stat-card{
  background:white;
  border-radius:24px;
  padding:25px;
  box-shadow:var(--shadow);
}

.stat-top{
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.stat-card h3{
  font-size:34px;
  margin-top:10px;
}

.stat-card p{
  color:var(--muted);
}

.stat-icon{
  width:60px;
  height:60px;
  border-radius:20px;

  display:flex;
  align-items:center;
  justify-content:center;

  color:white;
  font-size:22px;
}

.blue{
  background:linear-gradient(135deg,#2563eb,#60a5fa);
}

.green{
  background:linear-gradient(135deg,#16a34a,#4ade80);
}

.orange{
  background:linear-gradient(135deg,#ea580c,#fb923c);
}

.dark{
  background:linear-gradient(135deg,#0f172a,#334155);
}

/* ======================
   CARD
====================== */

.card{
  background:white;
  border-radius:26px;
  padding:28px;
  margin-bottom:28px;
  box-shadow:var(--shadow);
}

.card-title{
  display:flex;
  justify-content:space-between;
  align-items:center;
  flex-wrap:wrap;
  gap:15px;
  margin-bottom:24px;
}

.card-title h2{
  font-size:24px;
  font-weight:800;
}

/* ======================
   FORM
====================== */

.form-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:18px;
}

.full{
  grid-column:1/-1;
}

.form-group{
  display:flex;
  flex-direction:column;
  gap:8px;
}

label{
  font-size:14px;
  font-weight:700;
}

input,
textarea,
select{
  border:1px solid var(--border);
  padding:16px;
  border-radius:16px;
  outline:none;
  font-size:15px;
  transition:.25s;
}

input:focus,
textarea:focus,
select:focus{
  border-color:var(--primary);
  box-shadow:0 0 0 4px rgba(37,99,235,.1);
}

textarea{
  resize:none;
  min-height:120px;
}

/* ======================
   PROFILE
====================== */

.profile-upload{
  display:flex;
  align-items:center;
  gap:20px;
  margin-bottom:25px;
  flex-wrap:wrap;
}

.profile-upload img{
  width:110px;
  height:110px;
  border-radius:50%;
  object-fit:cover;
  border:4px solid var(--border);
}

/* ======================
   PRODUCT
====================== */

.product-image-preview{
  width:100%;
  height:260px;
  object-fit:cover;
  border-radius:22px;
  margin-bottom:22px;
  background:#f1f5f9;
}

.products-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:24px;
}

.product-card{
  background:white;
  border-radius:24px;
  overflow:hidden;
  box-shadow:var(--shadow);
  transition:.25s;
}

.product-card:hover{
  transform:translateY(-4px);
}

.product-card img{
  width:100%;
  height:240px;
  object-fit:cover;
}

.product-body{
  padding:20px;
}

.category{
  display:inline-block;
  background:#eff6ff;
  color:var(--primary);

  padding:7px 12px;
  border-radius:999px;

  font-size:12px;
  font-weight:700;

  margin-bottom:14px;
}

.product-body h3{
  margin-bottom:10px;
}

.price{
  font-size:30px;
  font-weight:800;
  color:var(--primary);
  margin-bottom:14px;
}

.meta{
  display:flex;
  flex-direction:column;
  gap:10px;
  color:var(--muted);
  margin-bottom:18px;
}

.product-actions{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
}

.product-actions .btn{
  flex:1;
}

/* ======================
   EMPTY
====================== */

.empty{
  background:white;
  padding:60px;
  border-radius:24px;
  text-align:center;
  color:#94a3b8;
  box-shadow:var(--shadow);
}

/* ======================
   LOADER
====================== */

.loader{
  position:fixed;
  inset:0;
  background:rgba(255,255,255,.7);

  display:none;
  align-items:center;
  justify-content:center;

  z-index:99999;
}

.spinner{
  width:65px;
  height:65px;
  border:5px solid #dbeafe;
  border-top:5px solid var(--primary);
  border-radius:50%;

  animation:spin 1s linear infinite;
}

@keyframes spin{
  100%{
    transform:rotate(360deg);
  }
}

/* ======================
   RESPONSIVE
====================== */

@media(max-width:950px){

  .mobile-menu-btn{
    display:flex;
    align-items:center;
    justify-content:center;
  }

  .sidebar{
    transform:translateX(-100%);
    transition:.3s;
  }

  .sidebar.active{
    transform:translateX(0);
  }

  .main{
    margin-left:0;
    width:100%;
    padding-top:90px;
  }
}

@media(max-width:700px){

  .form-grid{
    grid-template-columns:1fr;
  }

  .topbar{
    flex-direction:column;
    align-items:flex-start;
  }

  .search-box{
    width:100%;
  }

  .search-box input{
    width:100%;
  }

  .welcome h1{
    font-size:28px;
  }

  .card{
    padding:20px;
  }

  .products-grid{
    grid-template-columns:1fr;
  }
}

</style>
</head>

