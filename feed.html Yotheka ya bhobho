<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>OurMarket - Professional Marketplace Dashboard</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>

<style>

:root{
  --primary:#2563eb;
  --primary-dark:#1d4ed8;
  --danger:#dc2626;
  --success:#16a34a;
  --dark:#0f172a;
  --dark2:#111827;
  --bg:#f1f5f9;
  --card:#ffffff;
  --text:#0f172a;
  --muted:#64748b;
  --border:#e2e8f0;
  --shadow:0 10px 30px rgba(15,23,42,.08);
  --radius:22px;
  --sidebar:280px;
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

html{
  scroll-behavior:smooth;
}

body{
  font-family:"Inter",sans-serif;
  background:var(--bg);
  color:var(--text);
  min-height:100vh;
  display:flex;
  overflow-x:hidden;
}

img{
  display:block;
  max-width:100%;
}

button,
input,
textarea,
select{
  font-family:inherit;
}

button{
  cursor:pointer;
}

.section{
  display:none;
}

.section.active{
  display:block;
}

/* =========================
   MOBILE MENU
========================= */

.mobile-menu-btn{
  display:none;
  position:fixed;
  top:15px;
  left:15px;
  width:52px;
  height:52px;
  border:none;
  border-radius:16px;
  background:var(--primary);
  color:white;
  z-index:3000;
  font-size:20px;
  box-shadow:var(--shadow);
}

/* =========================
   SIDEBAR
========================= */

.sidebar{
  width:var(--sidebar);
  background:linear-gradient(180deg,var(--dark),var(--dark2));
  color:white;
  position:fixed;
  top:0;
  left:0;
  bottom:0;
  padding:24px 18px;
  display:flex;
  flex-direction:column;
  justify-content:space-between;
  z-index:2000;
}

.brand{
  display:flex;
  align-items:center;
  gap:14px;
  margin-bottom:40px;
}

.brand-logo{
  width:60px;
  height:60px;
  border-radius:18px;
  background:linear-gradient(135deg,#2563eb,#60a5fa);
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:25px;
}

.brand h2{
  font-size:24px;
  font-weight:800;
}

.nav{
  display:flex;
  flex-direction:column;
  gap:10px;
}

.nav-link{
  text-decoration:none;
  color:#cbd5e1;
  padding:16px 18px;
  border-radius:18px;
  display:flex;
  align-items:center;
  gap:14px;
  transition:.3s;
  font-weight:700;
}

.nav-link:hover,
.nav-link.active{
  background:rgba(255,255,255,.08);
  color:white;
}

.logout-btn{
  border:none;
  padding:16px;
  border-radius:18px;
  background:linear-gradient(135deg,#ef4444,#dc2626);
  color:white;
  font-weight:700;
}

/* =========================
   MAIN
========================= */

.main{
  margin-left:var(--sidebar);
  width:calc(100% - var(--sidebar));
  padding:30px;
}

/* =========================
   TOPBAR
========================= */

.topbar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  flex-wrap:wrap;
  gap:20px;
  margin-bottom:30px;
}

.welcome h1{
  font-size:36px;
  font-weight:800;
}

.welcome p{
  color:var(--muted);
  margin-top:6px;
}

.profile-mini{
  background:white;
  padding:10px 16px;
  border-radius:18px;
  display:flex;
  align-items:center;
  gap:12px;
  box-shadow:var(--shadow);
}

.profile-mini img{
  width:50px;
  height:50px;
  border-radius:50%;
  object-fit:cover;
}

/* =========================
   SEARCH
========================= */

.search-box{
  position:relative;
}

.search-box i{
  position:absolute;
  left:16px;
  top:50%;
  transform:translateY(-50%);
  color:var(--muted);
}

.search-box input{
  width:300px;
  padding:15px 16px 15px 46px;
  border:none;
  outline:none;
  border-radius:16px;
  background:white;
  box-shadow:var(--shadow);
}

/* =========================
   STATS
========================= */

.stats-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
  gap:22px;
  margin-bottom:28px;
}

.stat-card{
  background:white;
  padding:25px;
  border-radius:24px;
  box-shadow:var(--shadow);
}

.stat-top{
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.stat-card h3{
  font-size:34px;
  margin-top:10px;
}

.stat-card p{
  color:var(--muted);
}

.stat-icon{
  width:60px;
  height:60px;
  border-radius:20px;
  display:flex;
  align-items:center;
  justify-content:center;
  color:white;
  font-size:22px;
}

.blue{
  background:linear-gradient(135deg,#2563eb,#60a5fa);
}

.green{
  background:linear-gradient(135deg,#16a34a,#4ade80);
}

.orange{
  background:linear-gradient(135deg,#ea580c,#fb923c);
}

.dark{
  background:linear-gradient(135deg,#0f172a,#334155);
}

/* =========================
   CARD
========================= */

.card{
  background:white;
  border-radius:26px;
  padding:28px;
  margin-bottom:28px;
  box-shadow:var(--shadow);
}

.card-title{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:24px;
  gap:15px;
  flex-wrap:wrap;
}

.card-title h2{
  font-size:24px;
  font-weight:800;
}

/* =========================
   FORM
========================= */

.form-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:18px;
}

.full{
  grid-column:1/-1;
}

.form-group{
  display:flex;
  flex-direction:column;
  gap:8px;
}

label{
  font-size:14px;
  font-weight:700;
}

input,
textarea,
select{
  width:100%;
  border:1px solid var(--border);
  padding:16px;
  border-radius:16px;
  outline:none;
  transition:.3s;
  font-size:15px;
}

input:focus,
textarea:focus,
select:focus{
  border-color:var(--primary);
  box-shadow:0 0 0 4px rgba(37,99,235,.1);
}

textarea{
  min-height:120px;
  resize:none;
}

/* =========================
   BUTTONS
========================= */

.btn{
  border:none;
  padding:15px 22px;
  border-radius:16px;
  font-weight:700;
  transition:.3s;
}

.btn:hover{
  transform:translateY(-2px);
}

.btn-primary{
  background:linear-gradient(135deg,#2563eb,#60a5fa);
  color:white;
}

.btn-danger{
  background:#fee2e2;
  color:#dc2626;
}

.btn-secondary{
  background:#eff6ff;
  color:#2563eb;
}

/* =========================
   PROFILE
========================= */

.profile-upload{
  display:flex;
  align-items:center;
  gap:20px;
  flex-wrap:wrap;
  margin-bottom:25px;
}

.profile-upload img{
  width:120px;
  height:120px;
  border-radius:50%;
  object-fit:cover;
  border:4px solid var(--border);
}

/* =========================
   PRODUCT PREVIEW
========================= */

.product-image-preview{
  width:100%;
  height:300px;
  object-fit:cover;
  border-radius:22px;
  margin-bottom:24px;
  background:#e2e8f0;
  cursor:pointer;
}

/* =========================
   PRODUCTS
========================= */

.products-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
  gap:24px;
}

.product-card{
  background:white;
  border-radius:24px;
  overflow:hidden;
  box-shadow:var(--shadow);
  transition:.3s;
}

.product-card:hover{
  transform:translateY(-5px);
}

.product-card img{
  width:100%;
  height:240px;
  object-fit:cover;
  cursor:pointer;
}

.product-body{
  padding:22px;
}

.category{
  display:inline-block;
  background:#eff6ff;
  color:#2563eb;
  padding:7px 14px;
  border-radius:999px;
  font-size:12px;
  font-weight:700;
  margin-bottom:14px;
}

.product-body h3{
  margin-bottom:10px;
  font-size:24px;
}

.price{
  font-size:30px;
  font-weight:800;
  color:#2563eb;
  margin-bottom:14px;
}

.meta{
  display:flex;
  flex-direction:column;
  gap:10px;
  color:var(--muted);
  margin-bottom:20px;
}

.product-actions{
  display:flex;
  gap:12px;
  flex-wrap:wrap;
}

.product-actions .btn{
  flex:1;
}

/* =========================
   EMPTY
========================= */

.empty{
  background:white;
  padding:60px;
  border-radius:24px;
  text-align:center;
  color:#94a3b8;
  box-shadow:var(--shadow);
}

/* =========================
   LOADER
========================= */

.loader{
  position:fixed;
  inset:0;
  background:rgba(255,255,255,.7);
  display:none;
  align-items:center;
  justify-content:center;
  z-index:99999;
}

.spinner{
  width:65px;
  height:65px;
  border:5px solid #dbeafe;
  border-top:5px solid var(--primary);
  border-radius:50%;
  animation:spin 1s linear infinite;
}

@keyframes spin{
  100%{
    transform:rotate(360deg);
  }
}

/* =========================
   IMAGE MODAL
========================= */

.image-modal{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.92);
  display:none;
  align-items:center;
  justify-content:center;
  z-index:999999;
  padding:20px;
}

.image-modal.active{
  display:flex;
}

.image-modal img{
  max-width:95%;
  max-height:90vh;
  border-radius:20px;
  object-fit:contain;
}

.close-modal{
  position:absolute;
  top:20px;
  right:25px;
  width:50px;
  height:50px;
  border:none;
  border-radius:50%;
  background:white;
  color:#111;
  font-size:22px;
}

/* =========================
   RESPONSIVE
========================= */

@media(max-width:950px){

  .mobile-menu-btn{
    display:flex;
    align-items:center;
    justify-content:center;
  }

  .sidebar{
    transform:translateX(-100%);
    transition:.3s;
  }

  .sidebar.active{
    transform:translateX(0);
  }

  .main{
    margin-left:0;
    width:100%;
    padding-top:90px;
  }
}

@media(max-width:700px){

  .form-grid{
    grid-template-columns:1fr;
  }

  .products-grid{
    grid-template-columns:1fr;
  }

  .search-box{
    width:100%;
  }

  .search-box input{
    width:100%;
  }

  .welcome h1{
    font-size:28px;
  }

  .card{
    padding:20px;
  }
}

</style>
</head>

